# FREESOUND_API_KEY: Required for searching and downloading background sounds and music tracks.
# Get your token by registering an account at https://freesound.org/apiv2/apply/
FREESOUND_API_KEY="MY_FREESOUND_API_KEY"

# PORT: The port on which the Express backend and Vite preview will run.
PORT=3000

# APP_URL: The URL where this applet is hosted (optional, automatically set by AI Studio at runtime).
APP_URL="MY_APP_URL"
